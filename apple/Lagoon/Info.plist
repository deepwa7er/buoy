<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Allow plain HTTP to the lagoon server on the tailnet. The tailnet encrypts
	  transport (WireGuard), so cleartext HTTP over it is the suite's documented
	  model; the exception is scoped to this one host. Everything else still
	  requires HTTPS under App Transport Security.
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSExceptionDomains</key>
		<dict>
			<key>deepwa7er.tailcfab97.ts.net</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<false/>
			</dict>
		</dict>
	</dict>

	<!--
	  Background sync. iOS reconciles with the lagoon server from a periodic
	  BGAppRefreshTask; its identifier must be declared here for the scheduler
	  to accept the request, and "fetch" enables the background-refresh
	  capability. Both keys are ignored on macOS, which syncs on foreground,
	  on capture, and via pull-to-refresh / the toolbar button.
	-->
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.deepwa7er.Lagoon.refresh</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
	</array>
</dict>
</plist>
